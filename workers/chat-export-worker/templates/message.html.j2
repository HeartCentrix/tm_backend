{% import '_macros.html.j2' as m %}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ thread_name }} — single message — TMvault</title>
<link rel="stylesheet" href="../../../styles.css">
</head>
<body>
<div class="container">
  <header class="thread-header">
    <h1>{{ thread_name }}</h1>

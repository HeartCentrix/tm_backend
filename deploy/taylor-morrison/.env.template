# ═══════════════════════════════════════════════════════════════════════
# 2) GRAPH THROTTLING BEHAVIOUR
# ═══════════════════════════════════════════════════════════════════════
# 12 apps × 5 RPS = 60 RPS sustained. Stays well under tenant aggregate
# ceiling (~200 RPS) while leaving headroom for bursty $batch operations.

# Per-app token-bucket pace. 5 RPS is the proven sweet spot — Graph's
# documented per-app+tenant ceiling is ~10 RPS for OneDrive,
# ~16 RPS for mail. 5 RPS sustained leaves room for $batch bursts
# without provoking 429s.
GRAPH_APP_PACE_REQS_PER_SEC=5.0

# Hard cap on app slots scanned by config loader. We use 12; this gives
# room to add a few more if monitoring shows >5% 429 rate sustained.
GRAPH_APP_MAX=30

# When a 429 forces migration, stay on the failover app this many
# pages before checking the original. Higher = less flapping on bursty
# tenants like Taylor's first-sync window.
GRAPH_STICKY_PAGES_BEFORE_RETURN=25

# Cool-down beyond Retry-After after each 429. Prevents stampede when
# the original app's quota opens up. 2s is conservative for first sync.
GRAPH_POST_THROTTLE_BRAKE_MS=2000


# ═══════════════════════════════════════════════════════════════════════
# 3) USER_MAIL — small workload, defaults mostly fine
# ═══════════════════════════════════════════════════════════════════════
# 5k mailboxes × avg 5k messages = 25M emails. With per-folder delta
# and $batch attachment lists, well within capacity.

USER_MAIL_PARALLEL_FOLDERS=10
USER_MAIL_ATT_CONCURRENCY=8
USER_MAIL_ATT_BATCH=20
USER_MAIL_TIMEOUT_S=43200             # 12h per-mailbox timeout
USER_MAIL_FLUSH_BATCH=500


# ═══════════════════════════════════════════════════════════════════════
# 4) USER_ONEDRIVE — the 260 TiB elephant
# ═══════════════════════════════════════════════════════════════════════
# 5k drives × ~10k files = 50M files. Massive parallelism needed to
# saturate Taylor's pipe to Azure.

# How many files in flight per worker. With 8 light workers (below),
# 8 × 32 = 256 files in flight simultaneously across the worker pool.
ONEDRIVE_BACKUP_FILE_CONCURRENCY=32

# Files above this size take the parallel-range path. 32 MB threshold
# routes medium files (videos, design docs) through the resilient
# multi-segment downloader. Saved 49 MB .mov failures in baseline.
ONEDRIVE_LARGE_FILE_THRESHOLD_BYTES=33554432              # 32 MB

# 16 MB segments per parallel-range fetch. A 256 MB file → 16 segments.
# Sweet spot between TCP throughput and per-file RAM (4 segs × 16 MB
# = 64 MB peak per file).
ONEDRIVE_LARGE_FILE_SEGMENT_BYTES=16777216                # 16 MB
ONEDRIVE_LARGE_FILE_SEGMENT_CONCURRENCY=8

# Single-stream Range-resume (new in dev-am): if Graph CDN closes
# connection mid-stream, retry with `Range: bytes=N-` and continue.
# 6 attempts with exponential backoff (1/2/4/8/16/32 s).
ONEDRIVE_STREAM_MAX_RESUMES=6

# Huge files (CAD drawings, VM images, datasets) routed to heavy worker
BACKUP_HEAVY_THRESHOLD_BYTES=10737418240                  # 10 GB
BACKUP_HEAVY_QUEUE=backup.heavy
BACKUP_HEAVY_ENABLED=true
MAX_CONCURRENT_ONEDRIVE_BACKUPS_PER_WORKER=4

# OneDrive backup checkpoint cadence. When a worker dies mid-run,
# RabbitMQ redelivers the job to another worker and the new session
# resumes from the last saved BackupCheckpoint.
#
# At Taylor's scale (10-50k files per power user), the prior
# defaults (500 files / 1 GiB) only fired once or twice during a
# backup — meaning a mid-cycle crash could waste hours of work.
# 50 files / 256 MiB caps the worst-case wasted work to roughly 10%
# of a checkpoint window. Cost: ~1 extra DB UPDATE per 50 files
# (negligible vs the per-file Azure block-commit).
ONEDRIVE_BACKUP_CHECKPOINT_EVERY_FILES=50
ONEDRIVE_BACKUP_CHECKPOINT_EVERY_BYTES=268435456          # 256 MiB


# Inline-attachment threshold for mail + chat content. Items below
# this size are stored as base64 in snapshot_items.metadata.inline_b64
# instead of going through Azure Blob, which:
#
#   1. Avoids the per-blob block-list commit (200-500 ms / attachment).
#   2. Sidesteps the azure-storage-blob aiohttp transport bug that
#      raises 'Timeout on reading data from socket' on catt_* uploads
#      under high concurrency — observed to crash workers mid-backup
#      with ExitCode=0 (clean event-loop exit, no OOM), forcing
#      RabbitMQ to redeliver the job and waste prior progress.
#
# 1 MB catches ~95% of chat attachments and most email attachments.
# Larger items (huge file shares, video, big PDFs) still use Azure
# but those are rare enough that the SDK bug doesn't compound.
#
# Trade-off: bigger Postgres metadata column rows. At 5k users × ~1
# MB avg × thousands of attachments, projected DB growth ~2-3 TB
# of metadata. Mitigations:
#   - snapshot_items already has indices for tenant isolation
#   - JSONB column compresses well (TOAST)
#   - Raise to 512 KB if Postgres footprint becomes a hot spot
INLINE_ATTACHMENT_MAX_BYTES=1048576                       # 1 MB


# ═══════════════════════════════════════════════════════════════════════
# 5) USER_CHATS — Teams hosted-content / attachments
# ═══════════════════════════════════════════════════════════════════════

TEAMS_CHAT_EXPORT_CONCURRENCY=3
USER_CHATS_INTERLEAVE_HOSTED_CONTENT=true

# Cap for the per-message hostedContent / chat-attachment fan-out.
# Without this, every chat message with hostedContents fires in
# parallel, each spawning its own internal semaphore — so effective
# concurrency was msgs × per-msg-cap, easily hitting thousands.
# SharePoint CDN responds by dropping connections, which then need
# slow Range-resume retries. 16 keeps the network in a healthy zone
# at 1 Gbps; raise to 32 on 25 Gbps ExpressRoute if shared-URL bytes
# dominate Taylor's chat profile.
CHAT_HC_MSG_CONCURRENCY=16

# Range-resume cap for shared SharePoint URL downloads
# (referenceAttachments in mail + chat). Mirrors the OneDrive
# Range-resume — on peer-closed mid-stream, reissue GET with
# Range: bytes=N- and continue from offset. 6 × ~60s read = ~6 min
# worst case per attachment before degrading to metadata-only.
SHARED_URL_STREAM_MAX_RESUMES=6


# ═══════════════════════════════════════════════════════════════════════
# 6) WORKER CONCURRENCY
# ═══════════════════════════════════════════════════════════════════════
# Async tasks per worker. 200 leaves headroom for the multi-resource
# fan-out (mail folders + onedrive files + chats per user, parallel).
BACKUP_CONCURRENCY=200

# Default storage backend selection — Azure Blob is the target
# (SeaweedFS available as DR fallback).
AZURE_STORAGE_ACCOUNT_NAME=<taylor-backup-storage>
AZURE_STORAGE_ACCOUNT_KEY=<azure-storage-account-key>
AZURE_STORAGE_BLOB_ENDPOINT=https://<taylor-backup-storage>.blob.core.windows.net/


# ═══════════════════════════════════════════════════════════════════════
# 7) DR REPLICATION (260 TiB primary; replicate to secondary region)
# ═══════════════════════════════════════════════════════════════════════
# Cross-region async replication via server-side copy. Replicates blocks
# without re-pulling from M365. Costs are Azure egress + secondary
# storage.

DR_REGION_ENABLED=true
DR_REGION=westus3
DR_STORAGE_ACCOUNT_NAME=<taylor-backup-dr>
DR_STORAGE_ACCOUNT_KEY=<dr-storage-account-key>


# ═══════════════════════════════════════════════════════════════════════
# 8) DATABASE
# ═══════════════════════════════════════════════════════════════════════
# At 50M files + 25M emails + chats/contacts/calendar, snapshot_items
# will grow to ~80-100M rows. Postgres can handle this comfortably but
# tune for it: 16 GB RAM minimum, SSD, work_mem 64 MB.

DB_HOST=<postgres-host>
DB_PORT=5432
DB_USERNAME=tmvault
DB_PASSWORD=<db-password>
DB_NAME=tmvault_prod
POSTGRES_PASSWORD=<db-password>


# ═══════════════════════════════════════════════════════════════════════
# 9) RABBITMQ
# ═══════════════════════════════════════════════════════════════════════
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=tmvault
RABBITMQ_PASSWORD=<rabbitmq-password>

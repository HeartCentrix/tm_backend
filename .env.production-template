# =============================================================================
# TMvault production env template
# Sized for 250 TiB / 5,000 M365 users (avg 50 GB/user)
# Copy to .env and fill in the secrets, then deploy.
# =============================================================================

# -----------------------------------------------------------------------------
# Worker pool sizing
# -----------------------------------------------------------------------------
# Backup pool: 20 normal × 8GB + 5 heavy × 32GB = 320GB total RAM
# Average backup throughput: ~1-3 GB/min per worker. Daily incremental
# (~5% of 250 TiB ≈ 12.5 TiB) needs ~70 GB/min = 25 workers minimum.
BACKUP_WORKER_REPLICAS=20
BACKUP_HEAVY_REPLICAS=5

# Restore/export pool: 12 normal × 8GB + 4 heavy × 32GB = 224GB total RAM
# Each PST export holds the worker for 10min-4h. Plan for ~40 simultaneous
# user-initiated jobs at peak (1% of users). 12+4=16 worker slots; jobs
# beyond capacity queue gracefully.
RESTORE_WORKER_REPLICAS=12
RESTORE_HEAVY_REPLICAS=4

# Per-pod resource limits (sized for cloud worker tiers)
BACKUP_WORKER_MEM_LIMIT=8G
BACKUP_WORKER_MEM_RESERVE=2G
BACKUP_WORKER_CPU_LIMIT=4
BACKUP_HEAVY_MEM_LIMIT=32G
BACKUP_HEAVY_MEM_RESERVE=8G
BACKUP_HEAVY_CPU_LIMIT=8

RESTORE_WORKER_MEM_LIMIT=8G
RESTORE_WORKER_MEM_RESERVE=2G
RESTORE_WORKER_CPU_LIMIT=2
RESTORE_HEAVY_MEM_LIMIT=32G
RESTORE_HEAVY_MEM_RESERVE=8G
RESTORE_HEAVY_CPU_LIMIT=8

# -----------------------------------------------------------------------------
# Heavy-pool routing thresholds — catch whales sooner on large workloads
# -----------------------------------------------------------------------------
# OneDrive drives ≥ 50 GB → backup.heavy queue
BACKUP_HEAVY_ENABLED=true
BACKUP_HEAVY_THRESHOLD_BYTES=53687091200       # 50 GB

# PST/ZIP exports ≥ 20 GB → restore.heavy queue
HEAVY_EXPORT_ENABLED=true
HEAVY_EXPORT_THRESHOLD_BYTES=21474836480       # 20 GB
HEAVY_EXPORT_QUEUE=restore.heavy

# Item restores > 20 GB → restore.heavy queue
HEAVY_RESTORE_THRESHOLD_BYTES=21474836480      # 20 GB

# -----------------------------------------------------------------------------
# PST export tunables (whale-mailbox safety)
# -----------------------------------------------------------------------------
# Aspose.Email runtime: serialise PST writes per process (.NET runtime
# is single-threaded for our access pattern). Multiple replicas scale
# horizontally instead.
PST_WRITE_CONCURRENCY=1

# Memory pressure: warn + GC if RSS exceeds limit. 6GB on 8GB pods, 24GB
# on 32GB heavy pods. Set 0 to disable.
PST_MEMORY_LIMIT_MB=6144
PST_MEMORY_CHECK_INTERVAL=50

# Disk: refuse jobs that would fill /tmp. Multiplier accounts for PST +
# zip both on disk briefly during the final ZIP stream.
PST_DISK_OVERHEAD_MULTIPLIER=2.0
PST_DISK_FLOOR_BYTES=1073741824                # 1 GB safety floor

# Streaming knobs (bound memory regardless of mailbox size)
PST_FETCH_BATCH_SIZE=1000
PST_GROUP_FLUSH_AT=1000
PST_TOTAL_ACCUMULATED_CAP=5000
PST_AUTO_FOLDER_THRESHOLD=5000
PST_GROUP_TIMEOUT_S=14400                      # 4h per group cap

# Per-item retry policy
PST_ITEM_RETRY_MAX=3
PST_ITEM_RETRY_BACKOFF_BASE=0.5

# Attachment guard — replace oversize attachments with placeholder so
# one 5GB attachment can't OOM the worker.
PST_MAX_ATTACHMENT_BYTES=104857600             # 100 MB

# Per-USER concurrency cap (right shape for single-tenant + many users)
PST_RATE_LIMIT_SCOPE=user
PST_RATE_LIMIT_PER_KEY=3                        # each user can run 3 PST jobs in parallel
PST_CANCEL_CHECK_INTERVAL=10
PST_ZIP_BLOCK_SIZE=4194304                      # 4 MB zip stream block

# Aspose license (paid OEM in production; trial has 50-msg/folder cap +
# watermark). Choose ONE delivery method:
ASPOSE_EMAIL_LIC_B64=                           # base64-encoded .lic file
# ASPOSE_LICENSE_PATH=/run/secrets/aspose.lic  # bind-mounted file
# ASPOSE_LICENSE_KV_SECRET_NAME=                # Azure Key Vault secret name
# ASPOSE_LICENSE_KV_URL=                        # Azure Key Vault URL

# -----------------------------------------------------------------------------
# RabbitMQ — long-running jobs
# -----------------------------------------------------------------------------
# CRITICAL: also set in rabbitmq.conf:
#   consumer_timeout = 14400000
# Default 30-min ack timeout will redeliver long PST/restore jobs. We
# auto-resume from checkpoint, but redelivery wastes pool capacity.
RABBITMQ_USER=tmvault
RABBITMQ_PASSWORD=                              # generate strong password

# -----------------------------------------------------------------------------
# Storage — fill in for your backend
# -----------------------------------------------------------------------------
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
# OR for on-prem SeaweedFS:
# SEAWEEDFS_ENDPOINT=http://seaweedfs:8333
# SEAWEEDFS_ACCESS_KEY=
# SEAWEEDFS_SECRET_KEY=

# -----------------------------------------------------------------------------
# Microsoft Graph multi-app rotation
# -----------------------------------------------------------------------------
# Multiple Graph apps spread per-app rate limits across registrations.
# 3 apps gives 3× throughput before hitting per-app throttling.
APP_1_CLIENT_ID=
APP_1_CLIENT_SECRET=
APP_1_TENANT_ID=
APP_2_CLIENT_ID=
APP_2_CLIENT_SECRET=
APP_2_TENANT_ID=
APP_3_CLIENT_ID=
APP_3_CLIENT_SECRET=
APP_3_TENANT_ID=

AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# SharePoint REST cert (for SP API calls Graph can't do)
SHAREPOINT_CERT_PEM_B64=
SHAREPOINT_CERT_THUMBPRINT=

# -----------------------------------------------------------------------------
# Database — tune for the worker count
# -----------------------------------------------------------------------------
# Each worker holds ~5 DB connections. 25 workers × 5 = 125 connections.
# Plus services (job-service, snapshot-service etc): ~50 more.
# Set in postgresql.conf:
#   max_connections = 250
#   shared_buffers = 4GB
#   effective_cache_size = 12GB
DATABASE_URL=postgresql://postgres:CHANGEME@postgres:5432/railway
DB_NAME=railway
DB_HOST=postgres

# -----------------------------------------------------------------------------
# Redis — rate limit + caching
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# TM Vault Backend Configuration
# Copy this file to .env and update with your values

# Server
SERVER_PORT=8000
CORS_ORIGINS=["http://localhost:4200", "http://localhost:3000"]

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tm_vault_db
DB_USERNAME=tm_vault_admin
DB_PASSWORD=admin123

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Microsoft OAuth (app-only / application permissions)
# These belong to a multi-tenant Azure AD app with admin consent granted
# Required permissions: Directory.Read.All, User.Read.All, Group.Read.All,
#   Mail.Read, Files.Read.All, Sites.Read.All, ChannelMessage.Read.All,
#   Chat.Read.All, Contacts.Read, Calendars.Read, Notes.Read.All,
#   Tasks.Read.All, Application.Read.All, Policy.Read.All
MICROSOFT_CLIENT_ID=your-app-client-id
MICROSOFT_CLIENT_SECRET=your-app-client-secret
MICROSOFT_TENANT_ID=common

# Encryption key for storing secrets (Fernet key)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key

# Multi-App Registration (for mass backup - up to 10 apps)
# Each app gets its own Graph API rate limit
APP_1_CLIENT_ID=your-first-app-id
APP_1_CLIENT_SECRET=your-first-app-secret
APP_1_TENANT_ID=your-tenant-id
# APP_2_CLIENT_ID=your-second-app-id
# APP_2_CLIENT_SECRET=your-second-app-secret
# APP_2_TENANT_ID=your-tenant-id

# Redis (optional)
REDIS_ENABLED=false

# RabbitMQ (optional)
RABBITMQ_ENABLED=false

# Azure Storage (optional)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_BLOB_ENDPOINT= 

# Elasticsearch (optional)
ELASTICSEARCH_ENABLED=false

# ── Mail export (MBOX / EML) ─────────────────────────────────────────────────
# Streaming mail exporter — see docs/superpowers/specs/2026-04-19-mbox-mail-export-design.md.
# Default off. Enable in staging first, then per-tenant in prod.
EXPORT_MAIL_V2_ENABLED=false

# Parallelism: concurrent folder tasks per export job (per worker).
EXPORT_PARALLELISM=12

# Split each folder's MBOX at N bytes (default 5 GB, Veeam-parity).
EXPORT_MBOX_SPLIT_BYTES=5368709120

# Azure BlockBlob staging block size (4 MB default).
EXPORT_BLOCK_SIZE_BYTES=4194304

# Bounded asyncio queue between per-folder fetcher and writer — M3.
EXPORT_FOLDER_QUEUE_MAXSIZE=20

# M1 — hard cap on simultaneous export jobs per worker. Excess wait.
MAX_CONCURRENT_EXPORTS_PER_WORKER=2

# Messages prefetched per batch inside a folder task.
EXPORT_FETCH_BATCH_SIZE=50

# M6 — soft-kill when RSS > this % of container limit for grace seconds.
EXPORT_MEMORY_SOFT_LIMIT_PCT=80
EXPORT_MEMORY_KILL_GRACE_SECONDS=60

# ── OneDrive export v2 + backup uncap — see
#    docs/superpowers/specs/2026-04-19-onedrive-export-and-backup-uncap-design.md
EXPORT_ONEDRIVE_V2_ENABLED=false
EXPORT_ONEDRIVE_MISSING_POLICY=skip           # skip | retry | fail
EXPORT_ONEDRIVE_MAX_FILE_BYTES=214748364800   # 200 GB
EXPORT_ONEDRIVE_PATH_MAX_LEN=260
EXPORT_ONEDRIVE_SANITIZE_CHARS=<>:"/\|?*

ONEDRIVE_BACKUP_V2_ENABLED=false
ONEDRIVE_BACKUP_FILE_CONCURRENCY=16
MAX_CONCURRENT_ONEDRIVE_BACKUPS_PER_WORKER=4
ONEDRIVE_BACKUP_FILE_TIMEOUT_SECONDS=21600    # 6 h; 0 disables
ONEDRIVE_BACKUP_CHECKPOINT_EVERY_FILES=500
ONEDRIVE_BACKUP_CHECKPOINT_EVERY_BYTES=1073741824   # 1 GiB

BACKUP_HEAVY_ENABLED=false
BACKUP_HEAVY_THRESHOLD_BYTES=107374182400     # 100 GB
BACKUP_HEAVY_QUEUE=backup.heavy
BACKUP_WORKER_QUEUE=backup.normal

RABBITMQ_CONSUMER_HEARTBEAT_SECONDS=604800    # 1 week
RABBITMQ_CONSUMER_TIMEOUT_MS=604800000        # 1 week
